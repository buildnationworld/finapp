# --- Database ---------------------------------------------------------------
# Matches docker-compose.yml. Change credentials if you change the compose file.
DATABASE_URL="postgresql://pesapilot:pesapilot@localhost:5432/pesapilot?schema=public"

# --- Redis (used for BullMQ agent queue in later phases) --------------------
REDIS_URL="redis://localhost:6379"

# --- Auth -------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production-please-use-openssl-rand"
AUTH_URL="http://localhost:3000"

# --- Gemini -----------------------------------------------------------------
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

# --- App --------------------------------------------------------------------
NODE_ENV="development"
